<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_space_black">

    <com.albirich.RealmsAI.StarfieldView
        android:id="@+id/starfieldBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:padding="8dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/coverImageLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lorebook Cover"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/lorebookCoverImage"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder_avatar"
                app:shapeAppearanceOverlay="@style/RoundedImageCorners"
                app:layout_constraintTop_toBottomOf="@id/coverImageLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/loreTitleLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/lorebookCoverImage"
                app:counterMaxLength="40">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/loreTitleEt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Lorebook Title (e.g., Konoha Core)"
                    android:inputType="textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/loreDescLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:counterEnabled="true"
                app:counterMaxLength="200"
                app:layout_constraintTop_toBottomOf="@id/loreTitleLayout"
                app:helperTextTextColor="@color/white"
                app:counterTextColor="@color/white"
                app:helperText="A brief description for yourself and other users.">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/loreDescEt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="3"
                    android:hint="Description"
                    android:inputType="textMultiLine" />
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:id="@+id/divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#444444"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/loreDescLayout" />

            <TextView
                android:id="@+id/entriesHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lore Entries"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="16dp"
                android:layout_marginStart="8dp"
                app:layout_constraintTop_toBottomOf="@id/divider"
                app:layout_constraintStart_toStartOf="parent" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="@id/entriesHeader"
                app:layout_constraintStart_toEndOf="@id/entriesHeader"
                android:paddingStart="15dp"
                android:textSize="10dp"
                android:textColor="#919191"
                android:text="Data fed to the AI when keys are triggered"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/loreEntryRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="120dp"
                app:layout_constraintTop_toBottomOf="@id/entriesHeader" />

            <Button
                android:id="@+id/btnAddEntry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Add Knowledge Entry"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/loreEntryRecycler"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <Switch
                android:id="@+id/lorePrivateSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Private"
                android:textColor="@color/white"
                android:layout_marginTop="15dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnAddEntry"
                app:layout_constraintBottom_toTopOf="@id/btnSaveLorebook"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveLorebook"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Save Lorebook"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="32dp"
                app:layout_constraintTop_toBottomOf="@id/lorePrivateSwitch"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>