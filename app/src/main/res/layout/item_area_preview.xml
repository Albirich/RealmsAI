<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="4dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/areaCoverImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:layout_marginHorizontal="2dp"
        android:paddingTop="3dp"
        android:gravity="center_horizontal"
        android:adjustViewBounds="true"
        android:scaleType="fitCenter"
        android:src="@drawable/icon_01"
        android:contentDescription="@null"
        app:shapeAppearanceOverlay="@style/RoundedImageCorners"
        app:layout_constraintTop_toTopOf="@id/areaCardBackground"
        app:layout_constraintBottom_toBottomOf="@id/areaCardBackground"
        app:layout_constraintStart_toStartOf="@id/areaCardBackground"
        app:layout_constraintEnd_toEndOf="@id/areaCardBackground" />

    <ImageView
        android:id="@+id/areaCardBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitXY"
        android:src="@drawable/empty_card"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="4:5" />

    <!-- Name (reusing chatTitle id) -->
    <TextView
        android:id="@+id/areaTitle"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="18dp"
        android:layout_marginHorizontal="14dp"
        android:text="Area Name"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Summary (reusing chatPreview id) -->
    <TextView
        android:id="@+id/areaLocCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginHorizontal="14dp"
        android:layout_marginBottom="40dp"
        android:text="location counts goes here."
        android:textSize="14sp"
        android:textColor="#666"
        app:layout_constraintTop_toBottomOf="@id/areaTitle"
        app:layout_constraintStart_toStartOf="parent"/>

    <ScrollView
        android:id="@+id/descScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="24dp"
        android:paddingHorizontal="5dp"
        app:layout_constraintTop_toBottomOf="@id/areaLocCount"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:fillViewport="true"
        android:overScrollMode="always">

        <TextView
            android:id="@+id/areaPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="4dp"
            android:text="Area description goes here."
            android:textColor="#000"
            android:textSize="14sp" />
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
