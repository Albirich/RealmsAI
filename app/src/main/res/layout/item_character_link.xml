<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/outline"
    android:layout_marginBottom="12dp"
    android:padding="12dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/linkAvatarImage"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:scaleType="centerCrop"
        android:src="@drawable/placeholder_avatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/linkTargetName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Target Character Name"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/linkAvatarImage"
        app:layout_constraintEnd_toStartOf="@id/deleteLinkBtn"
        app:layout_constraintTop_toTopOf="@id/linkAvatarImage" />

    <ImageButton
        android:id="@+id/deleteLinkBtn"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="?android:selectableItemBackgroundBorderless"
        android:src="@drawable/ic_delete"
        android:scaleType="centerInside"
        android:contentDescription="Delete Link"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <include
        android:id="@+id/infoButtonLinkType"
        layout="@layout/info_button"
        android:layout_width="25dp"
        android:layout_height="25dp"
        app:layout_constraintTop_toTopOf="@id/linkTypeSpinner"
        app:layout_constraintBottom_toBottomOf="@id/linkTypeSpinner"
        app:layout_constraintStart_toStartOf="@id/linkTargetName" />

    <Spinner
        android:id="@+id/linkTypeSpinner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="5dp"
        android:backgroundTint="@color/white"
        app:layout_constraintStart_toEndOf="@id/infoButtonLinkType"
        app:layout_constraintEnd_toStartOf="@id/deleteLinkBtn"
        app:layout_constraintTop_toBottomOf="@id/linkTargetName" />

    <TextView
        android:id="@+id/triggerTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Triiger:"
        app:layout_constraintTop_toBottomOf="@id/linkTypeSpinner"
        app:layout_constraintStart_toStartOf="@id/linkTriggerDetailsBox"
        app:layout_constraintBottom_toTopOf="@id/linkTriggerDetailsBox"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/linkTriggerDetailsBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="8dp"
        app:counterEnabled="true"
        app:counterMaxLength="100"
        app:layout_constraintStart_toStartOf="@id/linkTargetName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/triggerTitle"
        app:helperTextTextColor="@color/white"
        app:counterTextColor="@color/white"
        app:helperText="What triggers the switch? (e.g., Getting knocked out)">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/linkTriggerDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="200dp"
            android:scrollbars="vertical"
            android:maxLines="5"
            android:overScrollMode="always"
            android:gravity="top|start"
            android:inputType="textMultiLine"/>
    </com.google.android.material.textfield.TextInputLayout>


</androidx.constraintlayout.widget.ConstraintLayout>