<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#222222"
    android:padding="16dp">

    <TextView
        android:id="@+id/dialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Edit Lore Entry"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Entry Name"
        android:textColor="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dialogTitle"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/entryNameLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/dialogTitle">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="Activation Keys (Comma Separated)"
            android:textColor="@color/white"/>
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/dialogEntryNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. The Great Calamity" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/keysInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/entryNameLayout"
        app:helperText="Comma separated triggers (e.g., hokage, hashirama, leader)"
        app:helperTextTextColor="#AAAAAA">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="Content (AI Knowledge)"
            android:textColor="@color/white"/>

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/dialogKeysInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. calamity, disaster, 100 years ago" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/contentInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/keysInputLayout"
        app:counterEnabled="true"
        app:counterMaxLength="500"
        app:counterTextColor="@color/white"
        app:helperTextTextColor="#AAAAAA">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/dialogContentInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="4"
            android:maxLines="8"
            android:gravity="top|start"
            android:scrollbars="vertical"
            android:hint="The actual facts, history, or rules the AI needs to know when this entry is triggered"/>
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@id/contentInputLayout">

        <Button
            android:id="@+id/dialogDeleteBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Delete"
            android:backgroundTint="#D32F2F"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/dialogCancelBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel"
            android:backgroundTint="#555555"
            android:layout_marginHorizontal="2dp"/>

        <Button
            android:id="@+id/dialogSaveBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Save"
            android:backgroundTint="@color/purple_500"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>