<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/sheetRootColumn"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/avatarView"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder_avatar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/nameView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Character Name"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="@id/avatarView"
            app:layout_constraintStart_toEndOf="@id/avatarView"
            app:layout_constraintEnd_toStartOf="@id/activeBtn" />

        <TextView
            android:id="@+id/controllerName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Controller Name"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:layout_constraintStart_toStartOf="@id/nameView"
            app:layout_constraintEnd_toEndOf="@id/nameView"
            app:layout_constraintTop_toBottomOf="@id/nameView"/>

        <Button
            android:id="@+id/activeBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Active"
            app:layout_constraintTop_toTopOf="@id/nameView"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/summaryHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Summary:"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="8dp"
            android:textColor="@color/purple_200"
            app:layout_constraintTop_toBottomOf="@id/avatarView"
            app:layout_constraintStart_toStartOf="parent"
            />

        <EditText
            android:id="@+id/summaryView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="A brief summary of the character."
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/summaryHeader"
            app:layout_constraintStart_toStartOf="@id/summaryHeader"
            app:layout_constraintEnd_toEndOf="parent"
            android:textColor="@color/edit_text_color_selector"/>

        <TextView
            android:id="@+id/physicalDetailsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/purple_200"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/summaryView"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/physicalDescText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/physicalDetailsText"
            app:layout_constraintStart_toStartOf="parent"
            android:textColor="@color/edit_text_color_selector" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <Button
        android:id="@+id/manageMemoriesBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Core Memories"
        app:layout_constraintTop_toBottomOf="@id/headerBlock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/searchLoreBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Search lorebooks"
        app:layout_constraintTop_toBottomOf="@id/manageMemoriesBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/linkedCharactersBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Character Links"
        app:layout_constraintTop_toBottomOf="@id/searchLoreBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/aiSettingsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp"
        android:padding="8dp"
        android:background="#1AFFFFFF"
        app:layout_constraintTop_toBottomOf="@id/linkedCharactersBtn"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Character Override Model:"
            android:textColor="@color/purple_200"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/modelSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:backgroundTint="@color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Temp"
                    android:textSize="12sp"
                    android:textColor="#AAAAAA" />

                <EditText
                    android:id="@+id/tempEditBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:hint="Default"
                    android:textColorHint="#555555"
                    android:backgroundTint="@color/purple_200"
                    android:textSize="14sp"
                    android:padding="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Top K"
                    android:textSize="12sp"
                    android:textColor="#AAAAAA" />

                <EditText
                    android:id="@+id/topKEditBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:hint="Default"
                    android:textColorHint="#555555"
                    android:backgroundTint="@color/purple_200"
                    android:textSize="14sp"
                    android:padding="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Top P"
                    android:textSize="12sp"
                    android:textColor="#AAAAAA" />

                <EditText
                    android:id="@+id/topPEditBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:hint="Default"
                    android:textColorHint="#555555"
                    android:backgroundTint="@color/purple_200"
                    android:textSize="14sp"
                    android:padding="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/colorSettingsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/aiSettingsSection"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bubble Color"
                android:textColor="#AAAAAA"
                android:textSize="12sp"/>
            <Spinner
                android:id="@+id/bubbleColorSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#888888"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="4dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Text Color"
                android:textColor="#AAAAAA"
                android:textSize="12sp"/>
            <Spinner
                android:id="@+id/textColorSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#888888"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/loreSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/colorSettingsSection"
        app:layout_constraintStart_toStartOf="parent"
        android:padding="12dp">

        <TextView
            android:id="@+id/sheetCreatorNotes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"/>


        <TextView
            android:id="@+id/personalityHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Personality"
            android:textColor="@color/purple_200"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/personalityText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/edit_text_color_selector"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/backstoryHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Backstory"
            android:textColor="@color/purple_200"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/backstoryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/edit_text_color_selector"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/loreAbilitiesHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Abilities"
            android:textColor="@color/purple_200"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/loreAbilitiesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/edit_text_color_selector"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/secretSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/loreSection"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp"
        android:background="#33FF0000"
        android:padding="12dp">

        <Button
            android:id="@+id/revealSecretBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reveal Secret Description"
            android:backgroundTint="@color/design_default_color_error"/>

        <EditText
            android:id="@+id/secretText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/edit_text_color_selector"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- RPG section wrapper so we can toggle it -->
    <LinearLayout
        android:id="@+id/rpgSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="@id/sheetRootColumn"
        app:layout_constraintEnd_toEndOf="@id/sheetRootColumn"
        app:layout_constraintTop_toBottomOf="@id/secretSection"
        android:layout_marginVertical="8dp">
            <!-- Class -->
            <TextView
                android:id="@+id/classView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Class: "/>

            <!-- HP -->
            <TextView
                android:id="@+id/hpView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HP: "/>

            <!-- Defense -->
            <TextView
                android:id="@+id/defenseView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Defense: "/>

            <!-- Stats -->
            <TextView
                android:id="@+id/statsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stats:"
                android:textStyle="bold"
                android:textSize="18sp"
                app:layout_constraintTop_toBottomOf="@id/defenseView"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="12dp"/>

            <LinearLayout
                android:id="@+id/statsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/statsHeader"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Abilities -->
            <TextView
                android:id="@+id/abilitiesHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Abilities:"
                android:textStyle="bold"
                android:textSize="18sp"
                app:layout_constraintTop_toBottomOf="@id/statsList"
                app:layout_constraintStart_toStartOf="parent"
                android:paddingTop="8dp"/>

            <TextView
                android:id="@+id/abilitiesView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ability 1, Ability 2"
                app:layout_constraintTop_toBottomOf="@id/abilitiesHeader"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Equipment -->
            <TextView
                android:id="@+id/equipmentHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Equipment:"
                android:textStyle="bold"
                android:textSize="18sp"
                app:layout_constraintTop_toBottomOf="@id/abilitiesView"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="12dp"/>

            <LinearLayout
                android:id="@+id/equipmentList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/equipmentHeader"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Status Effects -->
            <TextView
                android:id="@+id/statusHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status Effects:"
                android:textStyle="bold"
                android:textSize="18sp"
                app:layout_constraintTop_toBottomOf="@id/equipmentList"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="12dp"/>

            <LinearLayout
            android:id="@+id/statusList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/statusHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:paddingBottom="5dp"/>
    </LinearLayout>
    <LinearLayout
        android:id="@+id/moreInfoTV"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rpgSection"
        android:paddingTop="8dp">
            <!-- Status Effects -->
            <TextView
                android:id="@+id/moreInfoHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="More Info:"
                android:textStyle="bold"
                android:textSize="18sp"
                app:layout_constraintTop_toBottomOf="@id/rpgSection"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginTop="12dp"/>

            <TextView
                android:id="@+id/moreInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/moreInfoHeader"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:paddingBottom="5dp"/>
    </LinearLayout>

    <!-- VN relationships section -->
    <LinearLayout
        android:id="@+id/vnSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/moreInfoTV"
        android:paddingTop="8dp">

        <TextView
            android:id="@+id/vnHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Relationships"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/vnRelationshipsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
