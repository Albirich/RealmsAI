<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/areaRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/deep_space_black">

    <com.albirich.RealmsAI.StarfieldView
        android:id="@+id/starfieldBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ImageView
        android:id="@+id/backgroundImageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="1.0" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        android:padding="8dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/areaCreate"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/areaNameLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:counterMaxLength="40">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/areaNameEt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Area Name"
                    android:inputType="textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/areaDescLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                app:counterEnabled="true"
                app:counterMaxLength="200"
                app:layout_constraintTop_toBottomOf="@id/areaNameLayout"
                app:layout_constraintStart_toStartOf="parent"
                app:helperTextTextColor="@color/white"
                app:counterTextColor="@color/white"
                app:helperText="AI Context: Describe the environment, atmosphere, and rules of this area. Keep it concise to save tokens!">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/areaDescEt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="200dp"
                    android:scrollbars="vertical"
                    android:maxLines="4"
                    android:overScrollMode="always"
                    android:gravity="top|start"
                    android:hint="System Description (For the AI)"
                    android:inputType="textMultiLine" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/areaPublicInfoLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                app:counterEnabled="true"
                app:counterMaxLength="1000"
                app:layout_constraintTop_toBottomOf="@id/areaDescLayout"
                app:layout_constraintStart_toStartOf="parent"
                app:helperTextTextColor="@color/white"
                app:counterTextColor="@color/white"
                app:helperText="Community Lore: Tell other players about your world. This is not sent to the AI.">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/areaPublicInfoEt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="250dp"
                    android:scrollbars="vertical"
                    android:maxLines="6"
                    android:overScrollMode="always"
                    android:gravity="top|start"
                    android:hint="Public Lore &amp; Creator Notes"
                    android:inputType="textMultiLine" />
            </com.google.android.material.textfield.TextInputLayout>

            <Switch
                android:id="@+id/areaNsfwSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This Area contains NSFW themes or imagery"
                android:textColor="@color/white"
                app:layout_constraintTop_toBottomOf="@id/areaPublicInfoLayout"
                app:layout_constraintStart_toStartOf="parent"
                android:checked="false"
                android:padding="16dp" />

            <View
                android:id="@+id/divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#444444"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/areaNsfwSwitch" />

            <TextView
                android:id="@+id/locationsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Locations"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="16dp"
                android:layout_marginStart="8dp"
                app:layout_constraintTop_toBottomOf="@id/divider"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/locationsHelper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rooms, districts, or specific spots within this Area."
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginStart="8dp"
                app:layout_constraintTop_toBottomOf="@id/locationsHeader"
                app:layout_constraintStart_toStartOf="parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/locationCreateRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="120dp"
                app:layout_constraintTop_toBottomOf="@id/locationsHelper"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <Button
                android:id="@+id/btnAddLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Add Location"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/locationCreateRecycler"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <Switch
                android:id="@+id/areaPrivateSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Private"
                android:textColor="@color/white"
                android:layout_marginTop="15dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnAddLocation"
                app:layout_constraintBottom_toTopOf="@id/btnSaveArea"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveArea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Save Area"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="32dp"
                app:layout_constraintTop_toBottomOf="@id/areaPrivateSwitch"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>