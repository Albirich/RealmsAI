<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">


    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.albirich.RealmsAI.StarfieldView
            android:id="@+id/starfieldBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ImageView
            android:id="@+id/backgroundImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:alpha="1.0" />


        <!-- Title -->
        <TextView
            android:id="@+id/chatProfileTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Chat Title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="32dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"/>

        <LinearLayout
            android:id="@+id/authorLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/chatProfileTitle"
            app:layout_constraintStart_toStartOf="@id/chatProfileTitle">
            <!-- Author -->
            <TextView
                android:id="@+id/chatProfileAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="by @author"
                android:textSize="14sp"
                android:textColor="#3974D3"
                android:textStyle="italic"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/chatOriginalProfileAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Original by @author"
                android:textSize="14sp"
                android:textColor="#3974D3"
                android:textStyle="italic"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- SFW Badge -->
        <ImageView
            android:id="@+id/chatProfileSfwBadge"
            android:layout_width="50dp"
            android:layout_height="25dp"
            android:src="@drawable/sfw_badge"
            app:layout_constraintTop_toTopOf="@id/chatProfileTitle"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="24dp"
            android:contentDescription="SFW badge"/>


        <!-- Go to Session Button -->
        <Button
            android:id="@+id/chatProfileSessionButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="0dp"
            android:adjustViewBounds="true"
            android:scaleType="fitXY"
            android:text="start session"
            android:textSize="10dp"
            android:maxLines="1"
            app:layout_constraintTop_toBottomOf="@id/authorLayout"
            app:layout_constraintStart_toStartOf="@id/authorLayout"
            android:layout_marginEnd="24dp"
            android:minWidth="100dp"
            android:backgroundTint="#3974D3"
            android:textColor="#FFF"/>

        <ImageButton
            android:id="@+id/chatProfileShareButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_share"
            android:scaleType="fitCenter"
            android:padding="8dp"
            app:layout_constraintStart_toStartOf="@id/chatProfileReportButton"
            app:layout_constraintBottom_toTopOf="@id/chatProfileReportButton"
            app:layout_constraintEnd_toEndOf="@id/chatProfileReportButton"
            android:contentDescription="Share Character"/>

        <Button
            android:id="@+id/chatProfileReportButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#AA0000"
            android:text="Report"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            app:layout_constraintTop_toTopOf="@id/chatProfileSessionButton"
            app:layout_constraintBottom_toBottomOf="@id/chatProfileSessionButton"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="24dp" />

        <ImageView
            android:id="@+id/layoutoutline"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="-20dp"
            app:layout_constraintTop_toBottomOf="@id/chatProfileSessionButton"
            app:layout_constraintBottom_toBottomOf="@id/profilelayout"
            app:layout_constraintStart_toStartOf="@id/profilelayout"
            app:layout_constraintEnd_toEndOf="@id/profilelayout"
            android:src="@drawable/outline"
            android:scaleType="fitXY"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/profilelayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@id/layoutoutline"
            android:padding="15dp">
            <!-- Description -->
            <TextView
                android:id="@+id/chatProfileDescription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Chat description..."
                android:textSize="16sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="12dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"/>

            <!-- Characters Title -->
            <TextView
                android:id="@+id/charactersTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Characters"
                android:textStyle="bold"
                android:textSize="16sp"
                app:layout_constraintTop_toBottomOf="@id/chatProfileDescription"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="24dp"
                android:layout_marginTop="20dp"/>

            <!-- Characters RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/charactersRecyclerView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/charactersTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="4dp"
                android:layout_marginHorizontal="20dp"
                android:clipToPadding="false"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
