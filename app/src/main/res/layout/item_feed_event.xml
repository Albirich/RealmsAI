<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#1E1E24"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/feedAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/placeholder_avatar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/feedAuthorName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="User Name"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toTopOf="@id/feedAvatar"
            app:layout_constraintStart_toEndOf="@id/feedAvatar"
            app:layout_constraintEnd_toStartOf="@id/feedTimestamp"/>

        <TextView
            android:id="@+id/feedTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2h ago"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            app:layout_constraintTop_toTopOf="@id/feedAuthorName"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/feedTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Published a new Character"
            android:textColor="#BBBBBB"
            android:textSize="14sp"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/feedAuthorName"
            app:layout_constraintStart_toStartOf="@id/feedAuthorName"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/feedContent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Content goes here..."
            android:textColor="@color/white"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/feedAvatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/feedActionButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="View Content"
            android:textSize="12sp"
            android:backgroundTint="#8A2BE2"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/feedContent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>